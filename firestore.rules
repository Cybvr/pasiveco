rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'mdBW2iIUy2diyIrnK55s' ||
        (exists(userDocPath()) && get(userDocPath()).data.isAdmin == true)
      );
    }

    function isContentManager() {
      return isSignedIn() && (
        request.auth.uid == 'mdBW2iIUy2diyIrnK55s' ||
        isAdmin()
      );
    }

    match /users/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && (request.auth.uid == userId || isAdmin());
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /socialMeta/{documentId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /socialProfiles/{profileId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /socialPosts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /socialThreads/{threadId} {
      allow read, write: if isSignedIn();
    }

    match /analytics/{analyticsId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isAdmin();
    }

    match /blog_posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isContentManager();
    }

    match /features/{featureId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if true;
    }

    match /solutions/{solutionId} {
      allow read: if true;
      allow write: if isAdmin();
      allow create: if true;
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if (isSignedIn() && (request.auth.uid == request.resource.data.userId || request.resource.data.userId == 'mdBW2iIUy2diyIrnK55s')) || isAdmin();
      allow update: if (isSignedIn() && request.auth.uid == resource.data.userId) || 
                   isAdmin() ||
                   (isSignedIn() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['rating', 'reviewsCount', 'updatedAt']));
      allow delete: if (isSignedIn() && request.auth.uid == resource.data.userId) || isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (
        resource.data.sellerId == request.auth.uid || 
        resource.data.affiliate == request.auth.uid ||
        (request.auth.token.email != null && resource.data.customerEmail == request.auth.token.email) ||
        isAdmin()
      );
      allow create: if true;
      allow update, delete: if isAdmin();
    }

    match /templates/{templateId} {
      allow read: if true;
      allow read, write: if (isSignedIn() && request.auth.uid == resource.data.userId) || isAdmin();
      allow create: if (isSignedIn() && request.auth.uid == request.resource.data.userId) || isAdmin();
    }

    match /clicks/{clickId} {
        allow read, write: if isSignedIn();
        allow create: if true;
    }

    match /userSettings/{settingsId} {
      allow read, write: if (isSignedIn() && resource.data.userId == request.auth.uid) || isAdmin();
      allow create: if (isSignedIn() && request.resource.data.userId == request.auth.uid) || isAdmin();
    }

    match /communities/{communityId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.creatorId == request.auth.uid;
      allow update: if isSignedIn() && (
        resource.data.creatorId == request.auth.uid || 
        isAdmin() ||
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount', 'updatedAt']))
      );
      allow delete: if isSignedIn() && (resource.data.creatorId == request.auth.uid || isAdmin());
    }

    match /communityMembers/{memberId} {
      allow read: if true;
      allow create: if isSignedIn() && (request.resource.data.userId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isAdmin() || 
        get(/databases/$(database)/documents/communities/$(resource.data.communityId)).data.creatorId == request.auth.uid
      );
      allow update: if isAdmin();
    }

    match /feedbackResponses/{responseId} {
      allow create: if
        request.resource.data.keys().hasOnly([
          'firstName',
          'email',
          'satisfaction',
          'goal',
          'blocker',
          'source',
          'page',
          'createdAt'
        ]) &&
        request.resource.data.source == 'marketing-survey-page' &&
        request.resource.data.page == '/survey/feedback' &&
        request.resource.data.firstName is string &&
        request.resource.data.email is string &&
        request.resource.data.satisfaction is string &&
        request.resource.data.goal is string &&
        request.resource.data.blocker is string &&
        request.resource.data.firstName.size() <= 120 &&
        request.resource.data.email.size() <= 200 &&
        request.resource.data.satisfaction.size() <= 200 &&
        request.resource.data.goal.size() <= 2000 &&
        request.resource.data.blocker.size() <= 2000;

      allow read, update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
