rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function isAdmin() {
      return isSignedIn() &&
        exists(userDocPath()) &&
        get(userDocPath()).data.isAdmin == true;
    }

    function isContentManager() {
      return isSignedIn() &&
        (request.auth.uid == 'mdBW2iIUy2diyIrnK55s' || isAdmin());
    }

    // Users collection - allow read/write for own data, read/write/create for admins
    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;
      allow read, write, create: if isAdmin();
    }
    
    // QR codes collection - allow read/write for owner, read for admins
    match /qr_codes/{qrCodeId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }
    
    // User profiles collection
    match /user_profiles/{profileId} {
      // Allow public read access for public profiles
      allow read: if true; // Allow all reads for public bio pages
      // Allow if document ID matches user ID
      allow write: if isSignedIn() && request.auth.uid == profileId;
      // Allow if userId field matches authenticated user
      allow write: if isSignedIn() && request.auth.uid == resource.data.userId;
      // Allow creation if userId field matches authenticated user
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      // Temporarily allow demo data creation
      allow create: if request.resource.data.userId == 'mdBW2iIUy2diyIrnK55s';
      // Allow admin access
      allow read, write, create: if isAdmin();
    }
    
    // Analytics collection - allow read/write for owner, read for admins
    match /analytics/{analyticsId} {
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow read: if isAdmin();
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }
    
    // Blog posts - allow read for everyone, write for admins
    match /blog_posts/{postId} {
      allow read: if true;
      allow create, update, delete: if isContentManager();
    }
    
    // Features - allow read for everyone, write for admins
    match /features/{featureId} {
      allow read: if true;
      allow write: if isAdmin();
      // Temporarily allow create without auth for migration
      allow create: if true;
    }
    
    // Solutions - allow read for everyone, write for admins
    match /solutions/{solutionId} {
      allow read: if true;
      allow write: if isAdmin();
      // Temporarily allow create without auth for migration
      allow create: if true;
    }
    
    // Products - allow public read, write for owner, read for admins
    match /products/{productId} {
      allow read: if true; // Allow public read access
      allow write: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      // Temporarily allow demo data creation
      allow create: if request.resource.data.userId == 'mdBW2iIUy2diyIrnK55s';
      allow read: if isAdmin();
    }
    
    // Templates - allow read for everyone
    match /templates/{templateId} {
      allow read: if true;
      allow read, write: if isSignedIn() && request.auth.uid == resource.data.userId;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
    }
    
    // Scans tracking
    match /scans/{scanId} {
      allow read, write: if isSignedIn();
      allow create: if true; // Allow anonymous scan tracking
    }

    // Clicks tracking
    match /clicks/{clickId} {
      allow read, write: if isSignedIn();
      allow create: if true; // Allow anonymous click tracking
    }
    
    // Default deny rule for any other documents
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
